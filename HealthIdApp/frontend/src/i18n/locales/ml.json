  "landing":{"badge":"ഇന്ത്യയുടെ ഡിജിറ്റൽ ആരോഗ്യ അടിസ്ഥാന സൗകര്യം","headline":"ആരോഗ്യ രേഖകളുടെ <accent>ഭാവി</accent>","description":"ഒരു സുരക്ഷിത ഐഡന്റിറ്റി. എല്ലാ ആശുപത്രിയും. പൂർണ്ണ നിയന്ത്രണം.","ctaPrimary":"നിങ്ങളുടെ ഹെൽത്ത് ഐഡി സൃഷ്ടിക്കുക","ctaHospital":"ആശുപത്രികൾക്ക്","card1Title":"ഹെൽത്ത് കാർഡ്","card1Subtitle":"സജീവം • പരിശോധിച്ചു","card2Title":"സമ്മതം നൽകി","card2Subtitle":"അപ്പോളോ ആശുപത്രി • 2 മിനിറ്റ് മുമ്പ്","card2Status":"✓ OTP പരിശോധിച്ചു — 24 മണിക്കൂർ ആക്‌സസ്","card3Title":"രക്ത പരിശോധന","card3Subtitle":"12 ഏപ്രിൽ 2026","brandStatement":"നിങ്ങളുടെ ആരോഗ്യ ഡാറ്റ നിങ്ങളെ സേവിക്കണം — നിങ്ങൾ ഇനി പോകാത്ത ആശുപത്രികളിലെ പൊടി പിടിച്ച ഫയലുകളിൽ ചിതറിക്കിടക്കരുത്.","featuresLabel":"ഹെൽത്ത്ഐഡി എന്തുകൊണ്ട്","featuresTitle":"ഇന്ത്യയിൽ ആരോഗ്യ സംരക്ഷണം യഥാർത്ഥത്തിൽ എങ്ങനെ പ്രവർത്തിക്കുന്നു എന്നതിനായി നിർമ്മിച്ചത്","feature1Title":"ഏകീകൃത മെഡിക്കൽ ടൈംലൈൻ","feature1Desc":"എല്ലാ പ്രിസ്ക്രിപ്ഷനും, ലാബ് റിപ്പോർട്ടും, രോഗനിർണ്ണയവും — എല്ലാ ആശുപത്രിയിൽ നിന്നും — ഒരൊറ്റ ടൈംലൈനിൽ.","feature2Title":"OTP-അടിസ്ഥാന സമ്മതം","feature2Desc":"താക്കോൽ നിങ്ങളുടെ കൈയിൽ. നിങ്ങളുടെ വ്യക്തമായ OTP അനുമതി ഇല്ലാതെ ഒരു ആശുപത്രിക്കും നിങ്ങളുടെ രേഖകൾ കാണാൻ കഴിയില്ല.","feature3Title":"പരിശോധിച്ച ആശുപത്രികൾ","feature3Desc":"പ്ലാറ്റ്‌ഫോമിലെ എല്ലാ ആശുപത്രിയും സർക്കാർ-രജിസ്റ്റർ ചെയ്തതും പരിശോധിച്ചതുമാണ്.","feature4Title":"തൽക്ഷണ ഹെൽത്ത് കാർഡ്","feature4Desc":"നിങ്ങളുടെ QR കോഡുള്ള സ്കാൻ ചെയ്യാവുന്ന ഡിജിറ്റൽ ഹെൽത്ത് കാർഡ് സൃഷ്ടിക്കുക.","feature5Title":"അഡ്മിൻ മേൽനോട്ടവും വിശകലനവും","feature5Desc":"സർക്കാർ അഡ്മിനിസ്ട്രേറ്റർമാർക്ക് ആശുപത്രി രജിസ്ട്രേഷനുകൾ, രോഗി എൻറോൾമെന്റ് നിരക്കുകൾ കാണിക്കുന്ന റിയൽ-ടൈം ഡാഷ്‌ബോർഡ് ലഭിക്കും.","statsLabel":"സ്വാധീനം","statsTitle":"പ്രധാനപ്പെട്ട സംഖ്യകൾ","statHealthIds":"ഹെൽത്ത് ഐഡികൾ സൃഷ്ടിച്ചു","statHospitals":"പരിശോധിച്ച ആശുപത്രികൾ","statStates":"സംസ്ഥാനങ്ങൾ കവർ","statUptime":"അപ്‌ടൈം വിശ്വാസ്യത","processLabel":"ഇത് എങ്ങനെ പ്രവർത്തിക്കുന്നു","processTitle":"ഡിജിറ്റൽ ആരോഗ്യത്തിനുള്ള നാല് ഘട്ടങ്ങൾ","step1Title":"രജിസ്റ്റർ","step1Desc":"നിങ്ങളുടെ ആധാറും ഫോൺ നമ്പറും ഉപയോഗിച്ച് ഹെൽത്ത് ഐഡി സൃഷ്ടിക്കുക.","step2Title":"രേഖകൾ ലിങ്ക്","step2Desc":"ആശുപത്രികൾ നിങ്ങളുടെ രേഖകൾ സുരക്ഷിതമായി അപ്‌ലോഡ് ചെയ്യുന്നു.","step3Title":"ആക്‌സസ് നൽകുക","step3Desc":"പുതിയ ഡോക്ടർക്ക് നിങ്ങളുടെ ചരിത്രം ആവശ്യമുള്ളപ്പോൾ, ലളിതമായ OTP വഴി പങ്കിടുക.","step4Title":"സുരക്ഷിതമായിരിക്കുക","step4Desc":"എപ്പോൾ വേണമെങ്കിലും ആക്‌സസ് പിൻവലിക്കുക.","testimonialsLabel":"ശബ്ദങ്ങൾ","testimonialsTitle":"രോഗികളും ആശുപത്രികളും വിശ്വസിക്കുന്നു","testimonial1":"ഒടുവിൽ, പഴയ റിപ്പോർട്ടുകൾ നിറഞ്ഞ ഫോൾഡർ കൊണ്ടുപോകേണ്ടതില്ല.","testimonial2":"സമ്മത സംവിധാനം മികച്ചതാണ്.","testimonial3":"ഒരു ആശുപത്രി എന്ന നിലയിൽ, ഓൺബോർഡിങ് എളുപ്പമായിരുന്നു.","testimonial4":"രോഗി പ്രവേശന സമയം 40% കുറച്ചു.","testimonial5":"3 നഗരങ്ങളിലെ അമ്മൂമ്മയുടെ മുഴുവൻ മെഡിക്കൽ ചരിത്രം — ഇപ്പോൾ ഒരിടത്ത്.","testimonial6":"OTP സിസ്റ്റം വളരെ ലളിതമാണ്, എന്റെ മാതാപിതാക്കൾ പോലും ആശയക്കുഴപ്പമില്ലാതെ ഉപയോഗിക്കുന്നു.","faqLabel":"FAQ","faqTitle":"സാധാരണ ചോദ്യങ്ങൾ","faq1Q":"ഹെൽത്ത് ഐഡി എന്താണ്?","faq1A":"ഹെൽത്ത് ഐഡി എന്നത് ആശുപത്രികളിലെ നിങ്ങളുടെ എല്ലാ മെഡിക്കൽ രേഖകളും ലിങ്ക് ചെയ്യുന്ന നിങ്ങളുടെ അദ്വിതീയ ഡിജിറ്റൽ ഐഡന്റിറ്റിയാണ്.","faq2Q":"എന്റെ ഡാറ്റ എങ്ങനെ സ്വകാര്യവും സുരക്ഷിതവുമായി സൂക്ഷിക്കുന്നു?","faq2A":"നിങ്ങളുടെ രേഖകൾ എൻക്രിപ്റ്റ് ചെയ്തിരിക്കുന്നു, OTP-അടിസ്ഥാന സമ്മത സംവിധാനം വഴി മാത്രമേ ആക്‌സസ് ചെയ്യാൻ കഴിയൂ.","faq3Q":"ഏതെങ്കിലും ആശുപത്രിക്ക് എന്റെ രേഖകൾ ആക്‌സസ് ചെയ്യാൻ കഴിയുമോ?","faq3A":"ഇല്ല. സർക്കാർ-രജിസ്റ്റർ ചെയ്ത ആശുപത്രികൾക്ക് മാത്രമേ ആക്‌സസ് അഭ്യർത്ഥിക്കാൻ കഴിയൂ.","faq4Q":"ഹെൽത്ത്ഐഡി ഉപയോഗിക്കാൻ ചിലവുണ്ടോ?","faq4A":"ഹെൽത്ത്ഐഡി രോഗികൾക്ക് പൂർണ്ണമായും സൗജന്യമാണ്.","faq5Q":"ഫോൺ നഷ്ടപ്പെട്ടാൽ അല്ലെങ്കിൽ നമ്പർ മാറ്റിയാൽ?","faq5A":"നിങ്ങളുടെ ഹെൽത്ത് ഐഡി ആധാറുമായി ലിങ്ക് ചെയ്തിരിക്കുന്നു, ഐഡന്റിറ്റി പരിശോധന വഴി വീണ്ടെടുക്കാം.","ctaHeadline":"നിങ്ങളുടെ ആരോഗ്യ രേഖകൾ","ctaAccent":"പൊടി പിടിച്ച ഫോൾഡറിനേക്കാൾ മികച്ചത് അർഹിക്കുന്നു","ctaDescription":"ഇന്ത്യയുടെ വളരുന്ന ഡിജിറ്റൽ ആരോഗ്യ നെറ്റ്‌വർക്കിൽ ചേരൂ. രോഗികൾക്ക് സൗജന്യം.","ctaRegisterHospital":"നിങ്ങളുടെ ആശുപത്രി രജിസ്റ്റർ ചെയ്യുക","footerDesc":"ഇന്ത്യയുടെ ഡിജിറ്റൽ ആരോഗ്യ അടി